<component type="desktop-application">
    <id>io.github.baronsmv.linux-rt-upscaler</id>
    <name>Real-Time Upscaler</name>
    <summary>Upscale any X‑Window</summary>

    <developer id="io.github.baronsmv">
        <name>Mauricio Valentín Barón Salinas</name>
    </developer>

    <metadata_license>CC0-1.0</metadata_license>
    <project_license>GPL-3.0-or-later</project_license>
    <content_rating type="oars-1.1"/>

    <description>
        <p>A real-time SRCNN upscaler for any X‑Window (X11 or XWayland) that captures its content, upscales it to
            full-screen and forwards mouse events to the original window.
        </p>
        <ol>
            <li>Select a window from the list.</li>
            <li>Choose the upscaling model and other options.</li>
            <li>Enjoy the upscaled output in full screen.</li>
        </ol>
    </description>

    <launchable type="desktop-id">io.github.baronsmv.linux-rt-upscaler.desktop</launchable>

    <screenshots>
        <screenshot>
            <image>
                https://raw.githubusercontent.com/baronsmv/linux-rt-upscaler/6cb75c7a34ef53f3077b69cead94fd96ac70bbde/docs/gui/screenshots/light_01.png
            </image>
            <caption>Main window (light theme).</caption>
        </screenshot>
        <screenshot type="default">
            <image>
                https://raw.githubusercontent.com/baronsmv/linux-rt-upscaler/6cb75c7a34ef53f3077b69cead94fd96ac70bbde/docs/gui/screenshots/dark_02.png
            </image>
            <caption>Main window (dark theme).</caption>
        </screenshot>
    </screenshots>

    <url type="homepage">https://github.com/baronsmv/linux-rt-upscaler</url>
    <url type="vcs-browser">https://github.com/baronsmv/linux-rt-upscaler</url>
    <url type="bugtracker">https://github.com/baronsmv/linux-rt-upscaler/issues</url>

    <branding>
        <color type="primary" scheme_preference="light">#9b74c6</color>
        <color type="primary" scheme_preference="dark">#582d98</color>
    </branding>

    <!-- ONLY desktop supported -->
    <requires>
        <control>keyboard</control>
        <control>pointing</control>
        <display_length compare="ge">768</display_length>
    </requires>

    <releases>
        <release version="1.0.0.post4" date="2026-05-16">
            <description>
                <p>Initial Flatpak release.</p>
            </description>
        </release>
    </releases>
</component>
